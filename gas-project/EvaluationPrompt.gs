/**
 * 評価プロンプトを構築する（計画書v2準拠）
 * @param {Object} opts
 *   - parsedTranscript: 解析済みPlaudテキスト
 *   - level: 評価レベル (1, 2, 3)
 *   - selfEval: 自己評価データ
 *   - interviewType: 'real' or 'roleplay'
 *   - previousResult: 前回の評価結果（あれば）
 * @return {string} 完成したプロンプト
 */
function buildEvaluationPrompt(opts) {
  var level = opts.level || 2;
  var criteria;
  if (level === 1) {
    criteria = LEVEL1_CRITERIA;
  } else if (level === 3) {
    criteria = LEVEL3_CRITERIA;
  } else {
    criteria = LEVEL2_CRITERIA;
  }

  // 対話テキストをフォーマット
  var formattedTranscript = opts.parsedTranscript.utterances.map(function(u) {
    return '[' + u.time + '] ' + u.speaker + ': ' + u.text;
  }).join('\n');

  // 話者統計
  var statsText = [];
  var speakers = opts.parsedTranscript.speakers || [];
  var speakerStats = opts.parsedTranscript.speakerStats || {};
  speakers.forEach(function(s) {
    var st = speakerStats[s];
    if (st) {
      statsText.push(s + ': 発話' + st.utteranceCount + '回, 約' + st.totalChars + '文字');
    }
  });

  // 面接種別の説明
  var interviewTypeText = opts.interviewType === 'real'
    ? '実患者面接（実際の患者との面接）'
    : '模擬面接（ロールプレイ）';

  // 自己評価情報
  var selfEvalSection = '';
  if (opts.selfEval) {
    selfEvalSection = buildSelfEvalSection(opts.selfEval, level);
  }

  // 前回結果
  var previousSection = '';
  if (opts.previousResult) {
    previousSection = buildPreviousSection(opts.previousResult);
  }

  // レベル別トーン指示
  var toneInstruction = getToneInstruction(level);

  // レベル別出力フォーマット
  var outputFormat = getOutputFormat(level);

  var prompt = [
    'あなたは柔道整復学科の医療面接指導の専門家です。',
    '学生が行った医療面接の文字起こしデータを分析し、教科書の評価基準に基づいて詳細な評価を行ってください。',
    '',
    KNOWLEDGE_BASE,
    '',
    criteria,
    '',
    '---',
    '',
    '## 面接メタ情報',
    '- 面接種別: ' + interviewTypeText,
    '- 評価レベル: Level ' + level,
    '',
    '## 評価対象の面接テキスト',
    '',
    '### 話者情報',
    statsText.join('\n'),
    '',
    '※ 通常、Speaker 1 が柔整師（術者）役、Speaker 2 が患者役です。',
    '  文脈から判断して適切に割り当ててください。',
    '',
    '### 対話内容',
    formattedTranscript,
    '',
    selfEvalSection,
    previousSection,
    '---',
    '',
    toneInstruction,
    '',
    '## 評価上の特別指示',
    '',
    '### 三段階判定基準',
    '各項目を以下の三段階で判定してください：',
    '- **Good**: 適切に実施された',
    '- **Partial**: 試みはあるが不十分',
    '- **Poor**: 実施されていない',
    '',
    '### 患者の寡黙度への配慮',
    '患者の発話が少ない場合、閉ざされた質問（CQ）が増えるのは適切な対応です。',
    'CQ比率が高くても、患者の発話量が少ない文脈であれば減点しないでください。',
    '',
    '### 面接種別への配慮',
    opts.interviewType === 'real'
      ? '実患者面接です。患者の協力度や状況に応じた柔軟な対応を評価してください。教科書通りに進められない場面があっても、臨機応変な対応を評価に反映してください。'
      : '模擬面接（ロールプレイ）です。教科書の評価基準に忠実に判定してください。',
    '',
    '### グレード設計（Level 2以上）',
    '- S: 90〜100点（優秀）',
    '- A: 80〜89点（良好）',
    '- B: 70〜79点（合格）',
    '- C: 60〜69点（あと一歩）',
    '- 成長中: 59点以下',
    '※ 「D」や「不合格」の表現は使わないでください。59点以下は「成長中」としてください。',
    '※ 「成長中」の場合はできた点を先に3つ以上褒め、改善点は1つだけに絞ってください。',
    '',
    '### AI評価の限界',
    'テキストベースの評価のため、非言語コミュニケーション（表情・姿勢・声のトーンなど）は',
    '評価対象外です。このことを overallComment に含めてください。',
    '',
    outputFormat
  ].join('\n');

  return prompt;
}

/**
 * 自己評価セクションを構築
 */
function buildSelfEvalSection(selfEval, level) {
  var lines = [
    '---',
    '',
    '## 学生の自己評価データ',
    '※ AI評価との比較（ギャップ分析）のために参照してください。',
    ''
  ];

  if (level === 1 && selfEval.checks) {
    lines.push('### 自己チェック結果');
    var keys = Object.keys(selfEval.checks);
    keys.forEach(function(key) {
      lines.push('- 項目' + key + ': ' + (selfEval.checks[key] ? 'できた' : 'できなかった'));
    });
  } else if (selfEval.categoryScores) {
    lines.push('### カテゴリ別自己評価（5段階）');
    var cats = Object.keys(selfEval.categoryScores);
    cats.forEach(function(cat) {
      lines.push('- ' + cat + ': ' + selfEval.categoryScores[cat] + '/5');
    });
    if (selfEval.freeComment) {
      lines.push('');
      lines.push('### 自由記述');
      lines.push(selfEval.freeComment);
    }
    if (selfEval.focusPoint) {
      lines.push('');
      lines.push('### 意識して取り組んだこと');
      lines.push(selfEval.focusPoint);
    }
    if (selfEval.difficulty) {
      lines.push('');
      lines.push('### うまくいかなかった場面');
      lines.push(selfEval.difficulty);
    }
  }

  lines.push('');
  return lines.join('\n');
}

/**
 * 前回結果セクションを構築
 */
function buildPreviousSection(prev) {
  if (!prev) return '';

  var lines = [
    '---',
    '',
    '## 前回の評価結果（参考）',
    '- 前回日時: ' + (prev.timestamp || '不明'),
    '- 前回レベル: Level ' + (prev.level || '不明'),
    '- 前回スコア: ' + (prev.totalScore || '不明'),
    '- 前回グレード: ' + (prev.grade || '不明'),
    '- 前回の最優先アクション: ' + (prev.topPriority || '不明'),
    '',
    '※ 前回との比較に基づいた成長コメントを overallComment に含めてください。',
    '  特に前回の最優先アクションが今回改善されていれば、積極的に褒めてください。',
    ''
  ];

  return lines.join('\n');
}

/**
 * レベル別トーン指示を返す
 */
function getToneInstruction(level) {
  if (level === 1) {
    return [
      '## フィードバックのトーン指示',
      '',
      '**Level 1（入門）: コーチが応援するトーン**',
      '- できたことを先に多く伝えてください（最低3つ以上褒める）',
      '- 改善点は**1つだけ**に絞ってください',
      '- 改善点には**そのまま使える台本（セリフ例）**を必ず付けてください',
      '- 励ましと応援の言葉を豊富に使ってください',
      '- 「すごい！」「よくできています！」など前向きな表現を使ってください'
    ].join('\n');
  } else if (level === 3) {
    return [
      '## フィードバックのトーン指示',
      '',
      '**Level 3（応用）: 自己省察促進型**',
      '- 直接答えを与えるのではなく、問いかけ形式で振り返りを促してください',
      '- 「この場面で〜できた可能性はありませんか？」のような問いを3つ生成してください',
      '- 各問いにはヒント（答え）を併記してください（UIで折りたたみ表示します）',
      '- 良い点は具体的に認め、改善点は自ら気づけるように導いてください'
    ].join('\n');
  } else {
    return [
      '## フィードバックのトーン指示',
      '',
      '**Level 2（基本）: バランス型**',
      '- 良い点を3つ以上挙げてください',
      '- 改善点を3つ挙げてください',
      '- 改善点には「なぜ重要か」の理由と具体的な言い回し例を付けてください',
      '- 最優先アクション（次にやるべき1つ）を明確にしてください',
      '- 建設的で前向きなトーンを維持してください'
    ].join('\n');
  }
}

